{
  "version": 1,
  "target_frame_rate": 60,
  "ui_scale": 1.0,
  "viewport_quality": {
    "resolution_scale": 1.0,
    "anti_aliasing": "none",
    "upscale_filter": "bilinear",
    "shadows": "medium",
    "ambient_occlusion": "off",
    "reflections": "off",
    "bloom": false,
    "color_grading": false,
    "motion_blur": false,
    "post_processing": true
  },
  "blender_executable": "",
  "window": {
    "width": 1920,
    "height": 974,
    "maximized": true
  },
  "layout": {
    "showToolbar": true,
    "showStatusBar": true,
    "panels": [
      {
        "id": "project",
        "dock": "left",
        "visible": true
      },
      {
        "id": "hierarchy",
        "dock": "left",
        "visible": true
      },
      {
        "id": "assets",
        "dock": "bottom",
        "visible": true
      },
      {
        "id": "viewport",
        "dock": "center",
        "visible": true
      },
      {
        "id": "inspector",
        "dock": "right",
        "visible": true
      },
      {
        "id": "resource_inspector",
        "dock": "right",
        "visible": true
      },
      {
        "id": "plugin.external_asset_library.browser",
        "dock": "bottom",
        "visible": true
      },
      {
        "id": "plugin.external_asset_library.island_generator",
        "dock": "right",
        "visible": false
      },
      {
        "id": "settings",
        "dock": "right",
        "visible": false
      },
      {
        "id": "reflection",
        "dock": "right",
        "visible": false
      },
      {
        "id": "runtime",
        "dock": "right",
        "visible": false
      },
      {
        "id": "scheduler_graph",
        "dock": "right",
        "visible": false
      },
      {
        "id": "material_editor",
        "dock": "center",
        "visible": false
      },
      {
        "id": "ui_asset_editor",
        "dock": "center",
        "visible": false
      },
      {
        "id": "profiler",
        "dock": "right",
        "visible": false
      },
      {
        "id": "tests",
        "dock": "right",
        "visible": false
      },
      {
        "id": "console",
        "dock": "bottom",
        "visible": true
      },
      {
        "id": "package",
        "dock": "bottom",
        "visible": false
      }
    ]
  },
  "console_show_critical": true,
  "console_show_error": true,
  "console_show_warn": true,
  "console_show_message": true,
  "console_show_trace": false,
  "console_search": "",
  "asset_browser_type_filter": "",
  "asset_search": "",
  "ui_workspace": {
    "active_asset": "",
    "selected_profile": "",
    "preview_width": 390,
    "preview_height": 844
  },
  "console_channel_editor": true,
  "console_channel_project": true,
  "console_channel_assets": true,
  "console_channel_world": true,
  "console_channel_play": true,
  "console_channel_validate": true,
  "console_channel_tests": true
}